//counttable問題
//文字列 "banana" の各文字の出現回数を出してください。
//期待する出力
{
 b:1
 a:3
 n:2
}

//解答のヒント
// 文字列は配列のように扱える
//私の解答
const words = "banana";

const freq = {};

for (let i = 0; i < words.length; i++) {
	const w = words[i];

	if (!freq[w]) {
	   freq[w] = 0;
	}

	freq[w]++;
}

console.log(freq);

//上記の私の解答でも正解ですが、模範解答のようにもっと簡潔に書くこともできます。

//模範解答
const words = "banana";

const freq = {};

for (let i = 0; i < words.length; i++) {
	const w = words[i];
	freq[w] = (freq[w] || 0) + 1;
}

console.log(freq);
